# Never publish anything remotely.
prefix_rule(
    pattern = ["git", "push"],
    decision = "forbidden",
    justification = "Do not push automatically. The user will push manually.",
)

# Never delete files using rm.
prefix_rule(
    pattern = ["rm"],
    decision = "forbidden",
    justification = "Do not delete files. Modify or move them instead.",
)

prefix_rule(
    pattern = ["rmdir"],
    decision = "forbidden",
    justification = "Do not delete directories.",
)

# Block common forceful/destructive Git operations.
prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard working-tree changes.",
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Do not delete untracked files.",
)

prefix_rule(
    pattern = ["git", "checkout", "-f"],
    decision = "forbidden",
    justification = "Do not force-discard local changes.",
)

prefix_rule(
    pattern = ["git", "branch", "-D"],
    decision = "forbidden",
    justification = "Do not force-delete branches.",
)